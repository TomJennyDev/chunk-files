{
  "name": "chunk-files",
  "version": "1.0.0",
  "private": true,
  "description": "Chunk Files — AI-powered file processing & search monorepo",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@chunk-files/web",
    "dev:api": "turbo run dev --filter=@chunk-files/api",
    "dev:docs": "turbo run dev --filter=@chunk-files/docs",
    "dev:mcp": "turbo run dev --filter=@chunk-files/mcp-server",
    "dev:test": "turbo run dev --filter=@chunk-files/api --filter=@chunk-files/web",
    "dev:gateway": "turbo run dev --filter=@chunk-files/api-gateway",
    "dev:upload": "turbo run dev --filter=@chunk-files/upload-service",
    "dev:processing": "turbo run dev --filter=@chunk-files/processing-service",
    "dev:search": "turbo run dev --filter=@chunk-files/search-service",
    "dev:notify": "turbo run dev --filter=@chunk-files/notification-service",
    "dev:microservices": "turbo run dev --filter=@chunk-files/api-gateway --filter=@chunk-files/upload-service --filter=@chunk-files/processing-service --filter=@chunk-files/search-service --filter=@chunk-files/notification-service",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:infra": "docker compose up localstack elasticsearch kibana kafka redis kafka-init redis-commander kafka-ui -d",
    "docker:services": "docker compose up api-gateway upload-service processing-service search-service notification-service -d",
    "docker:all": "docker compose up -d"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
