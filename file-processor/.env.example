# Environment
NODE_ENV=development

# Application
APP_PORT=3000
APP_NAME=file-processor-api

# Worker
WORKER_CONCURRENCY=5
CHUNK_SIZE=5242880  # 5MB chunks

# AWS Configuration (LocalStack)
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# S3
S3_BUCKET_NAME=file-uploads
S3_FORCE_PATH_STYLE=true

# SQS
SQS_QUEUE_URL=http://localhost:4566/000000000000/file-processing-queue
SQS_POLLING_WAIT_TIME=20
SQS_MAX_MESSAGES=10
SQS_VISIBILITY_TIMEOUT=300

# OpenSearch (LocalStack)
ELASTICSEARCH_NODE=http://localhost:4566
ELASTICSEARCH_INDEX=file-chunks
ELASTICSEARCH_MAX_RETRIES=3
ELASTICSEARCH_REQUEST_TIMEOUT=30000

# File Processing
MAX_FILE_SIZE=524288000  # 500MB
ALLOWED_FILE_TYPES=.txt,.pdf,.doc,.docx,.md,.json,.xml,.csv
CHUNK_OVERLAP=100  # bytes overlap between chunks
