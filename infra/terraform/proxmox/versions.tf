# ============================================
# Provider Version Constraints — Proxmox VE
# Dùng bpg/proxmox — hỗ trợ Windows, Linux, Mac
# ============================================

terraform {
  required_version = ">= 1.5"

  required_providers {
    proxmox = {
      source  = "bpg/proxmox"
      version = "~> 0.69"
    }
    null = {
      source  = "hashicorp/null"
      version = "~> 3.2"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}
