# ============================================
# terraform.tfvars.example
# Copy thành terraform.tfvars rồi điền giá trị thực
# Mỗi service = 1 LXC container riêng trên Proxmox
# ============================================

# ---- Proxmox Connection ----
proxmox_endpoint        = "https://192.168.1.10:8006"
proxmox_api_token       = "root@pam!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_insecure        = true         # false nếu Proxmox dùng cert hợp lệ
proxmox_node            = "pve"        # tên node Proxmox (xem trong UI)
proxmox_ssh_user        = "root"
proxmox_ssh_private_key = "~/.ssh/id_rsa"

# ---- Project ----
project_name = "chunk-files"
environment  = "dev"

# ---- LXC Settings ----
ct_id_start        = 300              # CT ID bắt đầu, mỗi service +1
lxc_storage        = "local-lvm"      # Proxmox storage pool
lxc_network_bridge = "vmbr0"          # bridge mạng
lxc_template       = "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst"

# ---- Networking ----
lxc_ip_prefix = "192.168.1"          # để trống "" để dùng DHCP
lxc_gateway   = "192.168.1.1"
lxc_dns       = "1.1.1.1"
lxc_password  = "changeme"           # root password cho tất cả LXC

# IP mỗi service (octet cuối, define trong module):
#   localstack    → .10    (192.168.1.10)
#   elasticsearch → .11    (192.168.1.11)
#   kibana        → .12    (192.168.1.12)
#   prometheus    → .20    (192.168.1.20)
#   loki          → .21    (192.168.1.21)
#   tempo         → .22    (192.168.1.22)
#   grafana       → .23    (192.168.1.23)
#   otel          → .24    (192.168.1.24)
#   api           → .30    (192.168.1.30)
#   web           → .31    (192.168.1.31)

ssh_public_key       = "ssh-rsa AAAAB3Nz... your-key-here"
ssh_private_key_path = "~/.ssh/id_rsa"

# ---- Service Toggles (true/false) ----
enable_localstack    = true
enable_elasticsearch = true
enable_kibana        = true
enable_observability = true   # Grafana + Prometheus + Loki + Tempo + OTel
enable_api           = true
enable_web           = false

# ---- Service Config ----
elasticsearch_version  = "8.11.0"
localstack_services    = "s3,sqs,opensearch,kms,iam,logs,lambda"
grafana_admin_password = "admin123"

tags = ["chunk-files", "terraform", "docker"]

