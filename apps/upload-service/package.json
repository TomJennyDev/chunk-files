{
  "name": "@chunk-files/upload-service",
  "version": "1.0.0",
  "description": "Upload Service - Handles file uploads to S3, stores metadata in Redis, emits Kafka events",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
