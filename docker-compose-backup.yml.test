version: '3.8'

services:
  localstack:
    # Using localstack-persist for automatic persistence in Community Edition
    # https://github.com/GREsau/localstack-persist
    image: gresau/localstack-persist:4
    container_name: terraform-localstack-lab
    hostname: localstack
    ports:
      - "4566:4566"            # LocalStack Gateway (all services)
      - "4510-4559:4510-4559"  # External services port range
    environment:
      # Services to run - add more as needed
      - SERVICES=s3,sqs,sns,kms,dynamodb,lambda,apigateway,iam,cloudwatch,secretsmanager,ssm,ec2,ecr,ecs,rds
      - DEBUG=1
      - AWS_DEFAULT_REGION=us-east-1
      - EDGE_PORT=4566
      - LAMBDA_EXECUTOR=local            # Lambda executor mode
      - LAMBDA_REMOTE_DOCKER=0
      - EAGER_SERVICE_LOADING=1          # Load services on startup
      
      # localstack-persist specific configuration
      - PERSIST_FORMAT=json              # json (readable) or binary (faster, smaller)
      - PERSIST_FREQUENCY=10             # Persist changes every 10 seconds
      # - PERSIST_DEFAULT=1              # Default: persist all services
      # Optional: Disable persistence for specific services
      # - PERSIST_CLOUDWATCH=0
      # Or enable only specific services:
      # - PERSIST_DEFAULT=0
      # - PERSIST_DYNAMODB=1
      # - PERSIST_S3=1
      # - PERSIST_SQS=1
      
      # Optional: Enable LocalStack Pro features (uncomment if you have license)
      # - LOCALSTACK_API_KEY=${LOCALSTACK_API_KEY}
    volumes:
      # Persistence data - localstack-persist uses /persisted-data
      - "./data:/persisted-data"
      # Init scripts for S3, SQS, etc.
      - "./init-scripts:/etc/localstack/init/ready.d"
      # Optional: Lambda code
      - "./lambdas:/tmp/lambdas"
    networks:
      - localstack-lab
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:4566/_localstack/health"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

networks:
  localstack-lab:
    name: terraform-localstack-lab
    driver: bridge
